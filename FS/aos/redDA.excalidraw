    {
      "id": "-Oo5lJ_ARFWLmtvXbRcsz",
      "type": "text",
      "x": -900.9403478574463,
      "y": -848.6612598020242,
      "width": 736.4285714285717,
      "height": 121.29411764705884,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
